# Copy to ".env" in this folder (do not commit .env).
# Used by Firebase Functions v2 defineString() params at deploy/runtime.
#
# STRIPE_PRICE_ID = one-time price ID from Stripe Dashboard → Product → Pricing
# LIV_PUBLIC_URL  = origin where liv.html is served (no trailing slash)

STRIPE_PRICE_ID=price_replace_me
LIV_PUBLIC_URL=https://trillionaire-grind.github.io
