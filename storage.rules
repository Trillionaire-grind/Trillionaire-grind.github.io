rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isLivAdmin() {
      return request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.admin == true;
    }

    // Profile photos: owner upload; any signed-in member can view.
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Book covers, chapter scans, and page images (admin ingest).
    match /books/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if isLivAdmin()
        && request.resource.size < 50 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType == 'application/pdf'
        );
    }
  }
}
