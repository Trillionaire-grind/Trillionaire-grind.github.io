{
  "name": "the-minorities-functions",
  "description": "Stripe subscriptions, webhooks, and admin tools for The Minorities app",
  "engines": {
    "node": "20"
  },
  "main": "index.js",
  "scripts": {
    "serve": "firebase emulators:start --only functions --config ../firebase.minorities.json",
    "deploy": "firebase deploy --only functions --config ../firebase.minorities.json --project the-minorities",
    "lint": "eslint . || true"
  },
  "dependencies": {
    "express": "^4.21.2",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.3.0",
    "stripe": "^17.7.0"
  }
}
