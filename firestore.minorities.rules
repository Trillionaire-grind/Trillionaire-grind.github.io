rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userExists() {
      return signedIn() && exists(userPath());
    }

    function userData() {
      return get(userPath()).data;
    }

    function isMinAdmin() {
      return userExists() && userData().admin == true;
    }

    function userTier() {
      return userExists() && userData().tier is string ? userData().tier : 'free';
    }

    /** Paid support tier with no content library access. */
    function isWaterboyOnly() {
      return userTier() == 'waterboy';
    }

    function tierRank(t) {
      return t == 'vip' ? 4
        : t == 'starter' ? 3
        : t == 'bench' ? 2
        : t == 'waterboy' ? 1
        : 0;
    }

    /** Content tiers: bench < starter < vip. Waterboy excluded. */
    function minCanAccess(required) {
      let requiredTier = required == null ? 'free' : required;
      let tier = userTier();
      if (requiredTier == 'free') return true;
      if (tier == 'waterboy') return false;
      if (!userExists()) return false;
      return tierRank(tier) >= tierRank(requiredTier);
    }

    function isMemberChat() {
      return userTier() in ['bench', 'starter', 'vip'];
    }

    function isVipMember() {
      return userTier() == 'vip';
    }

    function profileCreate(data) {
      return data.keys().hasOnly([
          'email', 'displayName', 'username', 'bio', 'avatarUrl',
          'tier', 'admin', 'createdAt', 'updatedAt',
          'stripeCustomerId', 'stripeSubscriptionId', 'stripePriceId', 'subscriptionStatus'
        ])
        && data.email is string
        && data.displayName is string
        && data.username is string
        && data.bio is string
        && data.avatarUrl is string
        && data.tier == 'free'
        && data.admin == false
        && data.stripeCustomerId == null
        && data.stripeSubscriptionId == null
        && data.stripePriceId == null
        && data.subscriptionStatus == null;
    }

    function profileSelfUpdate(data) {
      let diff = data.diff(resource.data).affectedKeys();
      return diff.hasOnly(['displayName', 'username', 'bio', 'avatarUrl', 'updatedAt'])
        && data.displayName is string
        && data.displayName.size() <= 120
        && data.username is string
        && data.username.size() <= 40
        && data.bio is string
        && data.bio.size() <= 280
        && data.avatarUrl is string;
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isMinAdmin());
      allow create: if signedIn()
        && request.auth.uid == userId
        && profileCreate(request.resource.data);
      allow update: if signedIn()
        && request.auth.uid == userId
        && profileSelfUpdate(request.resource.data);
      allow delete: if false;
    }

    match /contentCards/{cardId} {
      allow read: if resource.data.active != false
        && (
          resource.data.locked != true
          || minCanAccess(resource.data.requiredTier)
          || isMinAdmin()
        );
      allow create, update, delete: if isMinAdmin();
    }

    match /posts/{postId} {
      allow read: if signedIn()
        && (
          resource.data.requiredTier == null
          || minCanAccess(resource.data.requiredTier)
          || resource.data.authorUid == request.auth.uid
          || isMinAdmin()
        );
      allow create: if signedIn()
        && isMemberChat()
        && !isWaterboyOnly()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.authorName is string
        && request.resource.data.authorName.size() > 0
        && request.resource.data.authorName.size() <= 120
        && request.resource.data.body is string
        && request.resource.data.body.size() <= 8000
        && request.resource.data.type in ['text', 'video']
        && request.resource.data.likesCount == 0
        && request.resource.data.commentsCount == 0
        && request.resource.data.official == false
        && request.resource.data.createdAt == request.time;
      allow update: if isMinAdmin()
        || (signedIn()
          && resource.data.authorUid == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'body', 'headline', 'videoUrl', 'imageUrl', 'updatedAt'
          ]));
      allow delete: if isMinAdmin()
        || (signedIn() && resource.data.authorUid == request.auth.uid);

      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && !isWaterboyOnly()
          && request.resource.data.authorUid == request.auth.uid
          && request.resource.data.authorName is string
          && request.resource.data.authorName.size() > 0
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000
          && request.resource.data.createdAt == request.time;
        allow update, delete: if isMinAdmin()
          || (signedIn() && resource.data.authorUid == request.auth.uid);
      }

      match /likes/{likeUid} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.auth.uid == likeUid
          && !isWaterboyOnly();
        allow delete: if signedIn() && request.auth.uid == likeUid;
      }
    }

    match /chatRooms/{roomId} {
      allow read: if signedIn()
        && (
          isMinAdmin()
          || (!resource.data.vip && isMemberChat())
          || (resource.data.vip && isVipMember())
        );
      allow create: if signedIn()
        && isMemberChat()
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 80
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.vip == false;
      allow update, delete: if isMinAdmin();

      match /messages/{messageId} {
        allow read: if signedIn()
          && (
            isMinAdmin()
            || (
              !get(/databases/$(database)/documents/chatRooms/$(roomId)).data.vip
              && isMemberChat()
            )
            || (
              get(/databases/$(database)/documents/chatRooms/$(roomId)).data.vip
              && isVipMember()
            )
          );
        allow create: if signedIn()
          && request.resource.data.senderUid == request.auth.uid
          && request.resource.data.senderName is string
          && request.resource.data.senderName.size() > 0
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 4000
          && request.resource.data.createdAt == request.time
          && (
            (
              !get(/databases/$(database)/documents/chatRooms/$(roomId)).data.vip
              && isMemberChat()
            )
            || (
              get(/databases/$(database)/documents/chatRooms/$(roomId)).data.vip
              && isVipMember()
            )
          );
        allow update, delete: if isMinAdmin()
          || (signedIn() && resource.data.senderUid == request.auth.uid);
      }

      match /members/{memberUid} {
        allow read: if signedIn();
        allow write: if isMinAdmin();
      }
    }

    match /learnSessions/{sessionId} {
      allow read: if signedIn()
        && (
          isMinAdmin()
          || minCanAccess(resource.data.requiredTier)
        );
      allow create, update, delete: if isMinAdmin();
    }

    match /stripeCheckoutSessions/{sessionId} {
      allow read, write: if false;
    }

    match /stripeEvents/{eventId} {
      allow read, write: if false;
    }
  }
}
