rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- TM Experience (single club: naples-sunrise-bay) ---
    function tmClub() {
      return 'naples-sunrise-bay';
    }

    function signedIn() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userExists() {
      return signedIn() && exists(userPath());
    }

    function userData() {
      return get(userPath()).data;
    }

    function userClubId() {
      return userExists() ? userData().clubId : '';
    }

    function normalizeClubId(value) {
      return value.lower();
    }

    function clubIdsMatch(storedClubId, expectedClubId) {
      return normalizeClubId(storedClubId) == normalizeClubId(expectedClubId);
    }

    // Signed in and in this club (or profile not created yet after Auth sign-in)
    function isTmMember() {
      return signedIn() && (
        !userExists()
        || clubIdsMatch(userClubId(), tmClub())
      );
    }

    function isTmAdmin() {
      return userExists() && (
        userData().role == 'admin'
        || userData().admin == true
        || userData().admin == 'true'
      );
    }

    function clubAgendaPath(clubId) {
      return /databases/$(database)/documents/clubs/$(clubId)/agendas/current;
    }

    function clubAgenda(clubId) {
      return get(clubAgendaPath(clubId));
    }

    function meetingIsLive(clubId) {
      return exists(clubAgendaPath(clubId))
        && clubAgenda(clubId).data.isLive == true;
    }

    function isVoteCounter(clubId) {
      return userExists()
        && exists(clubAgendaPath(clubId))
        && clubAgenda(clubId).data.roles.voteRole != null
        && (
          clubAgenda(clubId).data.roles.voteRole.userId == request.auth.uid
          || (
            clubAgenda(clubId).data.roles.voteRole.member == userData().name
            && userData().name.size() > 0
          )
        );
    }

    function canReadClub(clubId) {
      return clubId == tmClub() && isTmMember();
    }

    function canAccessUser(userId) {
      return request.auth.uid == userId
        || (
          isTmMember()
          && exists(/databases/$(database)/documents/users/$(userId))
          && get(/databases/$(database)/documents/users/$(userId)).data.clubId == tmClub()
        );
    }

    function isSpeechMetadataPayload() {
      return request.resource.data.keys().hasOnly(['path', 'title', 'speechTitle']);
    }

    // --- Liv Lakay ---
    function isLivFirestoreAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.admin == true;
    }

    function livProfileCreate(data) {
      return data.email is string
        && data.fullName is string
        && data.grade is string
        && data.books is list
        && data.admin == false
        && data.accessCodeId is string
        && !('clubId' in data)
        && !('role' in data);
    }

    function isLivUserDoc() {
      return userExists()
        && (!('clubId' in userData()) || userData().clubId == null || userData().clubId == '');
    }

    match /books/{bookId} {
      allow read: if signedIn();
      allow create, update, delete: if isLivFirestoreAdmin();

      match /chapters/{chapterId} {
        allow read: if signedIn();
        allow create, update, delete: if isLivFirestoreAdmin();

        match /pages/{pageId} {
          allow read: if signedIn();
          allow create, update, delete: if isLivFirestoreAdmin();
        }
      }
    }

    match /Books/{bookId} {
      allow read: if signedIn();
      allow create, update, delete: if isLivFirestoreAdmin();

      match /{document=**} {
        allow read: if signedIn();
        allow create, update, delete: if isLivFirestoreAdmin();
      }
    }

    // --- Liv Lakay purchased access codes (current) ---
    match /codesPurchased/{codeId} {
      allow get: if resource.data.used != true &&
        resource.data.active != false;

      allow update: if request.auth != null &&
        request.auth.uid != null &&
        resource.data.used != true &&
        resource.data.active != false &&
        request.resource.data.used == true &&
        request.resource.data.redeemedByUid == request.auth.uid;

      allow create, delete: if false;
    }

    // --- Liv Lakay access codes (legacy; older passes) ---
    match /accessCodes/{codeId} {
      allow get: if resource.data.consumed == false &&
        resource.data.active != false;

      allow update: if request.auth != null &&
        request.auth.uid != null &&
        resource.data.consumed == false &&
        resource.data.active != false &&
        request.resource.data.consumed == true &&
        request.resource.data.redeemedByUid == request.auth.uid;

      allow create, delete: if false;
    }

    match /stripeCheckoutSessions/{sessionId} {
      allow read, write: if false;
    }

    match /learnNotes/{noteId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null &&
        request.auth.token.email == "buildingwithkepler@gmail.com";
    }

    match /clubs/{clubId} {
      allow get: if resource.data.active != false;
      allow list, create, update, delete: if false;

      match /agendas/{agendaId} {
        allow read: if canReadClub(clubId) || isTmAdmin();
        allow create, update: if signedIn() && isTmAdmin();
        allow delete: if false;
      }
    }

    match /test/{docId} {
      allow read: if isTmMember() || isTmAdmin();
      allow create, update: if signedIn() && isTmAdmin();
      allow delete: if false;
    }

    match /votes/{voteId} {
      allow read: if signedIn() && (
        request.auth.uid == voteId
        || isTmAdmin()
        || (isVoteCounter(tmClub()) && meetingIsLive(tmClub()))
      );
      allow create, update: if signedIn()
        && request.auth.uid == voteId
        && meetingIsLive(tmClub())
        && request.resource.data.keys().hasOnly(['bestSpeaker', 'bestEvaluator', 'bestTable']);
      allow delete: if false;
    }

    match /feedback/{docId} {
      allow read, write: if false;
    }

    match /users/{userId} {
      // Single-club app: members read club profiles; admins can list everyone for role picker
      allow read: if signedIn() && (
        request.auth.uid == userId
        || isTmAdmin()
        || isTmMember()
      );
      allow create: if signedIn()
        && request.auth.uid == userId
        && (
          (
            clubIdsMatch(request.resource.data.clubId, tmClub())
            && request.resource.data.name is string
            && request.resource.data.email is string
            && !('role' in request.resource.data)
          )
          || livProfileCreate(request.resource.data)
        );
      allow update: if signedIn()
        && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'clubId', 'admin', 'accessCodeId']);
      allow delete: if false;

      match /speeches/{speechId} {
        allow read: if canAccessUser(userId) || isTmAdmin();
        allow create, update: if isTmAdmin()
          || (signedIn()
            && request.auth.uid == userId
            && isTmMember()
            && isSpeechMetadataPayload())
          || (signedIn()
            && request.auth.uid != userId
            && isTmMember()
            && canAccessUser(userId)
            && isSpeechMetadataPayload());
        allow delete: if isTmAdmin();

        match /feedback/{feedbackId} {
          allow read: if canAccessUser(userId) || isTmAdmin();
          allow create: if isTmMember()
            && request.auth.uid != userId
            && request.resource.data.keys().hasOnly(['feedback', 'authorName', 'fromUid'])
            && request.resource.data.feedback is string
            && request.resource.data.feedback.size() > 0
            && request.resource.data.feedback.size() <= 8000
            && request.resource.data.authorName is string
            && request.resource.data.authorName.size() > 0
            && request.resource.data.authorName.size() <= 120
            && request.resource.data.fromUid == request.auth.uid;
          allow update, delete: if false;
        }
      }
    }
  }
}
