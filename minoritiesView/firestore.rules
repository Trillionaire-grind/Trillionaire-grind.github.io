rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().data.admin == true;
    }

    function profileCreate(data) {
      return data.app == 'minorities'
        && data.email is string
        && data.displayName is string
        && data.username is string
        && data.tier == 'free'
        && data.subscriptionId == 'waterboy'
        && data.teamRole == 'member'
        && data.subscriptionStatus == 'none'
        && data.admin == false
        && !('stripeCustomerId' in data)
        && !('stripeSubscriptionId' in data);
    }

    function subscriptionPlanValid(data) {
      return data.subscriptionId in ['waterboy', 'bench', 'starter', 'owner']
        && data.tier in ['free', 'bench', 'starter', 'owner']
        && (
          (data.subscriptionId == 'waterboy' && data.tier == 'free')
          || (data.subscriptionId == 'bench' && data.tier == 'bench')
          || (data.subscriptionId == 'starter' && data.tier == 'starter')
          || (data.subscriptionId == 'owner' && data.tier == 'owner')
        );
    }

    function subscriptionSelfUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly(['subscriptionId', 'tier', 'subscriptionStatus', 'updatedAt'])
        && subscriptionPlanValid(request.resource.data)
        && request.resource.data.subscriptionStatus in ['none', 'active'];
    }

    function adminTeamRoleUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return isAdmin()
        && request.auth.uid != userId
        && changed.hasOnly(['teamRole', 'admin', 'updatedAt'])
        && request.resource.data.teamRole in ['member', 'creator', 'moderator', 'admin']
        && request.resource.data.admin == (request.resource.data.teamRole == 'admin');
    }

    function postCreate(data) {
      return data.authorUid == request.auth.uid
        && data.authorName is string
        && data.authorName.size() > 0
        && data.authorUsername is string
        && data.authorUsername.size() >= 2
        && data.type in ['text', 'video']
        && data.likes == 0
        && data.commentCount == 0;
    }

    function commentCreate(data) {
      return data.authorUid == request.auth.uid
        && data.authorName is string
        && data.text is string
        && data.text.size() > 0
        && data.text.size() <= 2000;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && profileCreate(request.resource.data);
      allow update: if isOwner(userId)
        && (
          subscriptionSelfUpdate()
          || (
            !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['tier', 'subscriptionId', 'subscriptionStatus', 'stripeCustomerId', 'stripeSubscriptionId', 'app', 'admin', 'teamRole'])
          )
        );
      allow update: if adminTeamRoleUpdate();
      allow delete: if false;

      match /fcmTokens/{tokenId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && request.resource.data.token is string
          && request.resource.data.token.size() > 0
          && request.resource.data.tier in ['free', 'bench', 'starter', 'owner'];
        allow delete: if isOwner(userId);
      }
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if signedIn() && postCreate(request.resource.data);
      allow update: if signedIn()
        && (
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentCount'])
            && request.resource.data.commentCount == resource.data.commentCount + 1
          )
          || (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
            && (
              request.resource.data.likes == resource.data.likes + 1
              || request.resource.data.likes == resource.data.likes - 1
            )
          )
        );
      allow delete: if isAdmin()
        || (signedIn() && resource.data.authorUid == request.auth.uid);

      match /comments/{commentId} {
        allow read: if true;
        allow create: if signedIn() && hasBenchAccess() && commentCreate(request.resource.data);
        allow update, delete: if false;
      }

      match /likes/{userId} {
        allow read: if true;
        allow create: if signedIn() && request.auth.uid == userId;
        allow delete: if signedIn() && request.auth.uid == userId;
        allow update: if false;
      }
    }

    match /contentCards/{cardId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /appConfig/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    function messageCreate(data) {
      return data.authorUid == request.auth.uid
        && data.authorName is string
        && data.text is string
        && data.text.size() > 0
        && data.text.size() <= 2000;
    }

    function roomCreate(data) {
      return data.name is string
        && data.name.size() > 0
        && data.name.size() <= 120
        && data.vip is bool
        && (!('preview' in data) || data.preview is string);
    }

    function subscriptionRank() {
      let sub = userDoc().data.subscriptionId;
      return sub == 'owner' ? 3
        : sub == 'starter' ? 2
        : sub == 'bench' ? 1
        : 0;
    }

    function hasBenchAccess() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && subscriptionRank() >= 1;
    }

    function isOwnerMember() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().data.tier == 'owner';
    }

    match /chatrooms/{roomId} {
      // Bench+ (and admins) can list rooms. VIP message content stays gated below.
      allow read: if signedIn() && (hasBenchAccess() || isAdmin());
      allow create: if signedIn()
        && roomCreate(request.resource.data)
        && (hasBenchAccess() || isAdmin());
      allow update: if signedIn()
        && hasBenchAccess()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['preview', 'lastMessageAt']);
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if signedIn()
          && hasBenchAccess()
          && (get(/databases/$(database)/documents/chatrooms/$(roomId)).data.vip != true || isOwnerMember());
        allow create: if signedIn() && hasBenchAccess() && messageCreate(request.resource.data)
          && (
            get(/databases/$(database)/documents/chatrooms/$(roomId)).data.vip != true
            || isOwnerMember()
          );
        allow update, delete: if false;
      }
    }

    match /stripeCheckoutSessions/{sessionId} {
      allow read, write: if false;
    }
  }
}
